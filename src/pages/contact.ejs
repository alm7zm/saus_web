<%- include('../components/header', {
  title: 'Contact',
  description: 'Get in touch with Industry 4.0 Aerospace &mdash; sponsorship enquiries, media requests, or general questions about our SUAS 2026 programme.',
  pageClass: 'page-contact',
  currentPage: 'contact',
  cssFiles, rootPath, team
}) %>

<main id="main-content">

  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="<%= rootPath %>index.html">Home</a>
        <span aria-hidden="true">&rsaquo;</span>
        <span aria-current="page">Contact</span>
      </nav>
      <h1 class="page-hero__title">Contact Us</h1>
      <p class=”page-hero__desc”>Sponsorship, media, collaboration, or just saying hello &mdash; we'd love to hear from you.</p>
    </div>
    <div class="divider-bar" aria-hidden="true"></div>
  </div>

  <section class="section" aria-labelledby="contact-heading">
    <div class="container">
      <div class="contact-layout">

        <!-- LEFT: INFO -->
        <div>
          <h2 class="section__title" id="contact-heading" style="margin-bottom: 1.5rem; font-size: 1.5rem;">Get in Touch</h2>
          <div class="info-cards">
            <div class="info-card">
              <div class="info-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <p class="info-card__label">Email</p>
                <p class="info-card__value"><a href="mailto:<%= team.email %>"><%= team.email %></a></p>
              </div>
            </div>
            <div class="info-card">
              <div class="info-card__icon info-card__icon--orange" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <p class="info-card__label">Location</p>
                <p class="info-card__value"><%= team.university %><br><%= team.location %></p>
              </div>
            </div>
            <div class="info-card">
              <div class="info-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div>
                <p class="info-card__label">Faculty Advisor</p>
                <p class="info-card__value"><%= team.facultyAdvisor.name %><br><a href="mailto:<%= team.facultyAdvisor.email %>"><%= team.facultyAdvisor.email %></a></p>
              </div>
            </div>
            <div class="info-card">
              <div class="info-card__icon info-card__icon--orange" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <p class="info-card__label">Response Time</p>
                <p class="info-card__value">Within 48 hours (academic term)</p>
              </div>
            </div>
          </div>

          <div style="margin-top: 2rem;">
            <p style="font-size: 0.82rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.75rem;">Follow Us</p>
            <div class="social-links">
              <a href="#" class="social-link" aria-label="GitHub">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
              </a>
              <a href="#" class="social-link" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href="#" class="social-link" aria-label="Instagram">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
              </a>
            </div>
          </div>

          <div class="map-placeholder" style="margin-top: 2rem;" aria-label="Map placeholder">
            <div class="map-placeholder__icon" aria-hidden="true">&#x1F4CD;</div>
            <p class="map-placeholder__text">Meridian Institute of Technology</p>
            <address class="map-placeholder__address">
              Engineering Building, Room 412<br>
              <%= team.location %>
            </address>
          </div>
        </div>

        <!-- RIGHT: FORM -->
        <div>
          <div class="form-card">
            <h2 class="form-card__title">Send a Message</h2>
            <p class="form-card__subtitle">Have a question about sponsorship, media access, or our engineering? We'll get back to you within 48 hours during term.</p>
            <form action="#" method="post" novalidate aria-label="Contact form">
              <div class="form-grid">
                <div class="form-group">
                  <label class="form-label" for="contact-first-name">First Name <span aria-hidden="true" style="color:var(--orange)">*</span></label>
                  <input class="form-input" type="text" id="contact-first-name" name="first_name" autocomplete="given-name" required placeholder="Jane">
                </div>
                <div class="form-group">
                  <label class="form-label" for="contact-last-name">Last Name <span aria-hidden="true" style="color:var(--orange)">*</span></label>
                  <input class="form-input" type="text" id="contact-last-name" name="last_name" autocomplete="family-name" required placeholder="Smith">
                </div>
              </div>
              <div class="form-group" style="margin-bottom: 1.25rem;">
                <label class="form-label" for="contact-email">Email Address <span aria-hidden="true" style="color:var(--orange)">*</span></label>
                <input class="form-input" type="email" id="contact-email" name="email" autocomplete="email" required placeholder="jane@example.com">
              </div>
              <div class="form-group" style="margin-bottom: 1.25rem;">
                <label class="form-label" for="contact-subject">Subject <span aria-hidden="true" style="color:var(--orange)">*</span></label>
                <select class="form-select" id="contact-subject" name="subject" required>
                  <option value="" disabled selected>Select a topic&hellip;</option>
                  <option value="sponsorship">Sponsorship Enquiry</option>
                  <option value="media">Media / Press Request</option>
                  <option value="collaboration">Research Collaboration</option>
                  <option value="recruitment">Recruitment / Joining</option>
                  <option value="general">General Question</option>
                </select>
              </div>
              <div class="form-group" style="margin-bottom: 1.5rem;">
                <label class="form-label" for="contact-message">Message <span aria-hidden="true" style="color:var(--orange)">*</span></label>
                <textarea class="form-textarea" id="contact-message" name="message" rows="5" required placeholder="Tell us what you'd like to discuss&hellip;"></textarea>
              </div>
              <button type="submit" class="form-submit">Send Message</button>
              <p class="form-note">By submitting this form you agree to our <a href="#">privacy policy</a>. We will only use your information to respond to your enquiry.</p>
            </form>
          </div>

          <!-- FAQ -->
          <div style="margin-top: 2.5rem;">
            <h2 class="section__title" style="font-size: 1.25rem; margin-bottom: 1.25rem;">Frequently Asked Questions</h2>
            <details class="faq-item">
              <summary>
                <span>How can I sponsor the team?</span>
                <span class="faq-icon" aria-hidden="true">+</span>
              </summary>
              <div class=”faq-answer”>Email us at <a href=”mailto:<%= team.email %>”><%= team.email %></a> with your proposed contribution &mdash; hardware, materials, software licences, or financial support. We'll send you our sponsorship prospectus and discuss benefit packages.</div>
            </details>
            <details class="faq-item">
              <summary>
                <span>Can I join the team as a student?</span>
                <span class="faq-icon" aria-hidden="true">+</span>
              </summary>
              <div class="faq-answer">We recruit new members at the start of each academic year. Students from all engineering disciplines are welcome. Contact us using the form above or send an email with your academic year and area of interest.</div>
            </details>
            <details class="faq-item">
              <summary>
                <span>Do you accept media or press requests?</span>
                <span class="faq-icon" aria-hidden="true">+</span>
              </summary>
              <div class=”faq-answer”>Yes &mdash; we welcome media coverage of our competition programme. Select “Media / Press Request” in the subject dropdown and tell us about your publication or broadcast outlet. We can arrange interviews with the team captain and faculty advisor.</div>
            </details>
            <details class="faq-item">
              <summary>
                <span>What is the SUAS competition?</span>
                <span class="faq-icon" aria-hidden="true">+</span>
              </summary>
              <div class="faq-answer">The AUVSI Student Unmanned Aerial Systems (SUAS) competition evaluates fully autonomous UAVs across tasks including obstacle avoidance, object detection, classification, and precision payload delivery. <%= achievements.competition.globalCompetitors %> teams compete globally each year.</div>
            </details>
          </div>
        </div>

      </div>
    </div>
  </section>

</main>

<%- include('../components/footer', { rootPath, team }) %>
<script defer src="<%= rootPath %>js/main.js"></script>
</body>
</html>

