<article class="member-card reveal">
  <div class="member-card__header">
    <div class="member-card__avatar member-card__avatar--<%= member.avatarColor %>" aria-hidden="true">
      <div class="member-card__avatar-pattern"></div>
      <span class="member-card__avatar-initials"><%= member.initials %></span>
    </div>
    <div class="member-card__info">
      <span class="badge badge--<%= member.badgeVariant || 'blue' %> member-card__role"><%= member.role %></span>
      <h3 class="member-card__name"><%= member.name %></h3>
      <p class="member-card__dept"><%= member.department %> · <%= member.year %></p>
    </div>
  </div>
  <div class="member-card__body">
    <p class="member-card__desc"><%= member.bio %></p>
  </div>
  <details class="member-detail">
    <summary>
      <span>View Details</span>
      <span class="member-detail__icon" aria-hidden="true">+</span>
    </summary>
    <div class="member-detail__content">
      <h4>Key Contributions</h4>
      <ul>
        <% member.contributions.forEach(function(c) { %>
        <li><%= c %></li>
        <% }); %>
      </ul>
      <h4>Background</h4>
      <p><%= member.background %></p>
      <h4>Contact</h4>
      <p><a href="mailto:<%= member.email %>"><%= member.email %></a></p>
    </div>
  </details>
</article>
