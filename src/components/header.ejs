<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%- description %>">
  <meta property="og:title" content="<%= title %> | <%= team.teamName %>">
  <meta property="og:description" content="<%- description %>">
  <meta property="og:type" content="website">
  <title><%= title %> | <%= team.teamName %></title>
  <link rel="icon" type="image/jpeg" href="<%= rootPath %>assets/team_logo.jpeg">
  <% cssFiles.forEach(function(f) { %>
  <link rel="stylesheet" href="<%= rootPath %><%= f %>">
  <% }); %>
</head>
<body class="<%= pageClass %>" data-page="<%= currentPage %>">
<a href="#main-content" class="skip-link">Skip to main content</a>
<%- include('navigation', { currentPage, rootPath, team }) %>
